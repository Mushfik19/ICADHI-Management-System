{
  "name": "icadhi-management-system",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "node scripts/dev.js",
    "web:dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "backend:dev": "npm --prefix backend run dev",
    "test:backend": "node backend/src/tests/routes.test.js",
    "launch:check": "node scripts/check-launch.js",
    "check": "npm run launch:check && npm run test:backend && npm run build && npm run frontend:build && npx oxlint ."
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "dotenv": "^17.4.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "oxlint": "^1.69.0",
    "vite": "^8.1.0"
  }
}
